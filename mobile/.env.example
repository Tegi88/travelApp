# Expo only exposes env vars prefixed with EXPO_PUBLIC_ to app code.
# NOTE: these end up in the client bundle, so only use test/sandbox credentials
# on mobile, or proxy real requests through the web app's API routes instead.
EXPO_PUBLIC_AMADEUS_CLIENT_ID=
EXPO_PUBLIC_AMADEUS_CLIENT_SECRET=
EXPO_PUBLIC_AMADEUS_BASE_URL=https://test.api.amadeus.com
EXPO_PUBLIC_HOTEL_PROVIDER=amadeus
EXPO_PUBLIC_DEFAULT_CURRENCY=USD
