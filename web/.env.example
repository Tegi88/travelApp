# Amadeus for Developers (https://developers.amadeus.com) - free "test" tier
# Used for both flight search and hotel search.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# "https://test.api.amadeus.com" for the free sandbox, "https://api.amadeus.com" for production
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Which hotel provider to use. Currently supported: "amadeus" | "none"
# Set to "none" to always use rich mock hotel data.
HOTEL_PROVIDER=amadeus

# Default currency for prices when the user hasn't specified one
DEFAULT_CURRENCY=USD
